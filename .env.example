ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# Embedding backend: "voyage" (default) or "gemini" — configure the one you use.
EMBED_BACKEND=voyage
VOYAGE_API_KEY=pa-...your-voyage-key-here...

# Gemini backend — pick ONE auth mode:
#  (a) Gemini Developer API: set an API key (free tier / pay-as-you-go).
GEMINI_API_KEY=...your-gemini-key-here...
#  (b) Vertex AI via ADC (uses a Google Cloud trial credit; no API key). Set the
#      vars below, then run:  gcloud auth application-default login
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# ── Generation / cost (optional) ─────────────────────────────────────────────
# Chat model and the per-answer $ estimate shown in the UI metrics line + logs.
# Defaults below are Sonnet 4.6 list price ($3 / $15 per MTok in / out); override
# if you switch model or pricing changes. cost_usd covers LLM inference only
# (embedding cost is not included).
# CHAT_MODEL=claude-sonnet-4-6
# COST_PER_INPUT_TOKEN=3e-6
# COST_PER_OUTPUT_TOKEN=15e-6
